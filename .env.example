# Copy to .env and fill in. .env is git-ignored — keys never enter the repo.
# Everything runs at T0 (no keys) by default; these unlock T1/T2 grounding.

# T2 — live SERP signals for data-driven calendar prioritization (SerpApi.com)
export SERPAPI_KEY=''

# T2 (optional alternative) — DataForSEO, if you have a working account
# export DATAFORSEO_LOGIN=''
# export DATAFORSEO_PASSWORD=''

# T1 — Google Search Console (performance tracking) uses an OAuth credentials JSON;
# point config.yaml -> grounding.credentials.gsc_credentials_path at the file instead.
